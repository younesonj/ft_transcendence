      {
        "id": 7,
        "title": "Total Services Online",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 5 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "count(up == 1)", "legendFormat": "Online", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 5 }] }
          }
        },
        "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "justifyMode": "center" }
      },
      {
        "id": 8,
        "title": "Total HTTP Requests / min",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 5 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "(sum(rate(auth_http_requests_total[5m])) + sum(rate(chat_http_requests_total[5m])) + sum(rate(user_http_requests_total[5m]))) * 60", "legendFormat": "req/min", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "super-light-blue", "value": null }] }
          }
        },
        "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "justifyMode": "center" }
      },
      {
        "id": 9,
        "title": "Avg Response Time",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "avg(histogram_quantile(0.50, sum(rate(auth_http_request_duration_seconds_bucket[5m])) by (le)) or histogram_quantile(0.50, sum(rate(user_http_request_duration_seconds_bucket[5m])) by (le)) or histogram_quantile(0.50, sum(rate(chat_http_request_duration_seconds_bucket[5m])) by (le)))", "legendFormat": "p50 latency", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
          }
        },
        "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "justifyMode": "center" }
      },

      {
        "id": 101,
        "type": "row",
        "title": "📊  HTTP Traffic & Latency",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
        "collapsed": false
      },
      {
        "id": 10,
        "title": "Request Rate by Service",
        "description": "HTTP requests per second across all services",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "sum(rate(auth_http_requests_total[5m]))", "legendFormat": "Auth", "refId": "A" },
          { "expr": "sum(rate(chat_http_requests_total[5m]))", "legendFormat": "Chat", "refId": "B" },
          { "expr": "sum(rate(user_http_requests_total[5m]))", "legendFormat": "Users", "refId": "C" },
          { "expr": "sum(rate(listings_http_requests_total[5m]))", "legendFormat": "Listings", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "auto",
              "gradientMode": "scheme",
              "spanNulls": true,
              "axisBorderShow": false,
              "scaleDistribution": { "type": "linear" }
            },
            "color": { "mode": "palette-classic" }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },
      {
        "id": 11,
        "title": "Response Time — P95 Latency",
        "description": "95th percentile request duration per service",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 12, "y": 10 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "histogram_quantile(0.95, sum(rate(auth_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Auth p95", "refId": "A" },
          { "expr": "histogram_quantile(0.95, sum(rate(chat_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Chat p95", "refId": "B" },
          { "expr": "histogram_quantile(0.95, sum(rate(user_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Users p95", "refId": "C" },
          { "expr": "histogram_quantile(0.95, sum(rate(listings_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "Listings p95", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 15,
              "lineWidth": 2,
              "pointSize": 5,
              "showPoints": "auto",
              "gradientMode": "scheme",
              "spanNulls": true,
              "axisBorderShow": false
            },
            "color": { "mode": "palette-classic" }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },
      {
        "id": 12,
        "title": "HTTP Status Codes — Auth",
        "description": "Breakdown of response codes",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 6, "x": 0, "y": 19 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "sum by (status_code) (rate(auth_http_requests_total[5m]))", "legendFormat": "{{status_code}}", "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": { "mode": "normal" }, "gradientMode": "scheme" }
          },
          "overrides": [
            { "matcher": { "id": "byRegexp", "options": "^2" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
            { "matcher": { "id": "byRegexp", "options": "^4" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
            { "matcher": { "id": "byRegexp", "options": "^5" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
