      {
        "id": 102,
        "type": "row",
        "title": "🔧  Service Resources — CPU, Memory & Node.js Runtime",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
        "collapsed": false
      },
      {
        "id": 20,
        "title": "Memory Usage by Service",
        "description": "Resident Set Size (RSS) — actual RAM consumed",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 0, "y": 27 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "auth_process_resident_memory_bytes", "legendFormat": "Auth", "refId": "A" },
          { "expr": "chat_process_resident_memory_bytes", "legendFormat": "Chat", "refId": "B" },
          { "expr": "user_process_resident_memory_bytes", "legendFormat": "Users", "refId": "C" },
          { "expr": "listings_process_resident_memory_bytes", "legendFormat": "Listings", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true, "axisBorderShow": false },
            "color": { "mode": "palette-classic" }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },
      {
        "id": 21,
        "title": "CPU Time by Service",
        "description": "Rate of CPU seconds consumed per service",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 12, "y": 27 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "rate(auth_process_cpu_seconds_total[5m]) * 100", "legendFormat": "Auth", "refId": "A" },
          { "expr": "rate(chat_process_cpu_seconds_total[5m]) * 100", "legendFormat": "Chat", "refId": "B" },
          { "expr": "rate(user_process_cpu_seconds_total[5m]) * 100", "legendFormat": "Users", "refId": "C" },
          { "expr": "rate(listings_process_cpu_seconds_total[5m]) * 100", "legendFormat": "Listings", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true },
