        "description": "V8 heap memory usage per service",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "auth_nodejs_heap_size_used_bytes", "legendFormat": "Auth used", "refId": "A" },
          { "expr": "auth_nodejs_heap_size_total_bytes", "legendFormat": "Auth total", "refId": "B" },
          { "expr": "chat_nodejs_heap_size_used_bytes", "legendFormat": "Chat used", "refId": "C" },
          { "expr": "chat_nodejs_heap_size_total_bytes", "legendFormat": "Chat total", "refId": "D" },
          { "expr": "user_nodejs_heap_size_used_bytes", "legendFormat": "Users used", "refId": "E" },
          { "expr": "user_nodejs_heap_size_total_bytes", "legendFormat": "Users total", "refId": "F" },
          { "expr": "listings_nodejs_heap_size_used_bytes", "legendFormat": "Listings used", "refId": "G" },
          { "expr": "listings_nodejs_heap_size_total_bytes", "legendFormat": "Listings total", "refId": "H" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true },
            "color": { "mode": "palette-classic" }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },

      {
        "id": 103,
        "type": "row",
        "title": "🌐  HTTP Probe Overview",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
        "collapsed": false
      },
      {
        "id": 40,
        "title": "HTTP Probe Overview",
        "description": "Probes all service endpoints via Blackbox Exporter — status, SSL, TLS, cert expiry, latency, DNS",
        "type": "table",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 53 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "probe_success{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "A" },
          { "expr": "probe_http_status_code{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "B" },
          { "expr": "probe_http_ssl{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "C" },
          { "expr": "probe_ssl_earliest_cert_expiry{job=\"blackbox-http\"} - time()", "format": "table", "instant": true, "refId": "D" },
          { "expr": "probe_duration_seconds{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "E" },
          { "expr": "probe_dns_lookup_time_seconds{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "F" },
          { "expr": "probe_tls_version_info{job=\"blackbox-http\"}", "format": "table", "instant": true, "refId": "G" }
        ],
        "transformations": [
          {
            "id": "seriesToColumns",
            "options": { "byField": "instance" }
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "Time 1": true,
                "Time 2": true,
                "Time 3": true,
                "Time 4": true,
                "Time 5": true,
                "Time 6": true,
                "Time 7": true,
                "__name__": true,
                "__name__ 1": true,
                "__name__ 2": true,
                "__name__ 3": true,
                "__name__ 4": true,
                "__name__ 5": true,
                "__name__ 6": true,
                "__name__ 7": true,
                "job": true,
                "job 1": true,
                "job 2": true,
                "job 3": true,
                "job 4": true,
                "job 5": true,
                "job 6": true,
                "job 7": true,
                "version": true
              },
              "indexByName": {
                "instance": 0,
                "Value #A": 1,
                "Value #B": 2,
                "Value #C": 3,
                "version": 4,
                "Value #D": 5,
                "Value #E": 6,
                "Value #F": 7
              },
              "renameByName": {
                "instance": "Instance",
                "Value #A": "Status",
                "Value #B": "Code",
                "Value #C": "SSL",
                "Value #D": "SSL Cert Expiry (days)",
                "Value #E": "Probe Duration (s)",
                "Value #F": "DNS Lookup Duration (s)",
                "Value #G": "TLS Version"
              }
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "cellOptions": { "type": "auto" },
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Status" },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    { "options": { "0": { "text": "DOWN", "color": "dark-red" } }, "type": "value" },
                    { "options": { "1": { "text": "UP", "color": "dark-green" } }, "type": "value" }
                  ]
                },
                { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
                { "id": "custom.width", "value": 80 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Code" },
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "dark-green", "value": null },
                      { "color": "dark-green", "value": 200 },
                      { "color": "yellow", "value": 300 },
                      { "color": "orange", "value": 400 },
                      { "color": "dark-red", "value": 500 }
                    ]
                  }
                },
                { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
                { "id": "color", "value": { "mode": "thresholds" } },
                { "id": "custom.width", "value": 70 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "SSL" },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    { "options": { "0": { "text": "", "color": "text" } }, "type": "value" },
                    { "options": { "1": { "text": "OK", "color": "dark-green" } }, "type": "value" }
                  ]
                },
                { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
                { "id": "custom.width", "value": 60 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "SSL Cert Expiry (days)" },
              "properties": [
                { "id": "unit", "value": "s" },
                { "id": "decimals", "value": 0 },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "dark-red", "value": null },
                      { "color": "orange", "value": 604800 },
                      { "color": "yellow", "value": 2592000 },
                      { "color": "dark-green", "value": 7776000 }
                    ]
                  }
                },
                { "id": "color", "value": { "mode": "thresholds" } },
                { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
                { "id": "max", "value": 31536000 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Probe Duration (s)" },
              "properties": [
                { "id": "unit", "value": "s" },
                { "id": "decimals", "value": 2 },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "dark-green", "value": null },
                      { "color": "yellow", "value": 0.5 },
                      { "color": "orange", "value": 1 },
                      { "color": "dark-red", "value": 2 }
                    ]
                  }
                },
                { "id": "color", "value": { "mode": "thresholds" } },
                { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
                { "id": "max", "value": 3 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "DNS Lookup Duration (s)" },
              "properties": [
                { "id": "unit", "value": "s" },
                { "id": "decimals", "value": 3 },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "color": "dark-green", "value": null },
                      { "color": "yellow", "value": 0.1 },
                      { "color": "dark-red", "value": 0.5 }
                    ]
                  }
                },
                { "id": "color", "value": { "mode": "thresholds" } },
                { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
                { "id": "max", "value": 1 }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Instance" },
              "properties": [
                { "id": "custom.width", "value": 250 }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "cellHeight": "sm",
          "footer": { "show": false },
          "sortBy": [{ "displayName": "Status", "desc": true }]
        }
      },

      {
        "id": 104,
        "type": "row",
        "title": "🖥  Infrastructure — Host System Metrics",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 },
        "collapsed": false
      },
      {
        "id": 30,
        "title": "System CPU",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 4, "x": 0, "y": 64 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 31,
        "title": "System RAM",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 4, "x": 4, "y": 64 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM %", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 32,
        "title": "Disk Usage",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 4, "x": 8, "y": 64 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/host\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/host\",fstype!=\"tmpfs\"})) * 100", "legendFormat": "Disk %", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 33,
        "title": "CPU Usage Over Time",
        "type": "timeseries",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 64 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %", "refId": "A" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true },
            "color": { "fixedColor": "semi-dark-orange", "mode": "fixed" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }] }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
      },
      {
        "id": 34,
        "title": "Memory — Used vs Available",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 71 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used", "refId": "A" },
          { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "B" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 30, "lineWidth": 2, "gradientMode": "scheme", "stacking": { "mode": "normal" }, "spanNulls": true }
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-red", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-green", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 35,
        "title": "Network I/O",
        "description": "Bytes received and transmitted per second",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 71 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])", "legendFormat": "⬇ Receive {{device}}", "refId": "A" },
          { "expr": "-rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])", "legendFormat": "⬆ Transmit {{device}}", "refId": "B" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true }
          },
          "overrides": [
            { "matcher": { "id": "byRegexp", "options": "Receive" }, "properties": [{ "id": "color", "value": { "fixedColor": "super-light-green", "mode": "fixed" } }] },
            { "matcher": { "id": "byRegexp", "options": "Transmit" }, "properties": [{ "id": "color", "value": { "fixedColor": "super-light-blue", "mode": "fixed" } }] }
          ]
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } }
      }
    ],
    "editable": false,
    "schemaVersion": 39,
    "version": 2
  },
  "overwrite": true
}
