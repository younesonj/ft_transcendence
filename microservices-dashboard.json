{
  "dashboard": {
    "id": null,
    "uid": "microservices-overview",
    "title": "ft_transcendence — Platform Observatory",
    "description": "Real-time monitoring for all microservices, infrastructure, and system health",
    "tags": ["microservices", "prometheus", "production"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "style": "dark",
