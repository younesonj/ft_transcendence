        "targets": [{ "expr": "up{instance=\"auth:3004\"}", "refId": "A" }],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "options": { "0": { "text": "OFFLINE", "color": "dark-red" } }, "type": "value" },
              { "options": { "1": { "text": "ONLINE", "color": "dark-green" } }, "type": "value" }
            ],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "dark-red", "value": null }, { "color": "dark-green", "value": 1 }] }
          }
        },
        "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "justifyMode": "center" }
      },
