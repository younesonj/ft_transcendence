        "id": 23,
        "title": "Active Handles & Requests",
        "description": "Open handles (sockets, timers) and active libuv requests",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "auth_nodejs_active_handles_total", "legendFormat": "Auth handles", "refId": "A" },
          { "expr": "chat_nodejs_active_handles_total", "legendFormat": "Chat handles", "refId": "B" },
          { "expr": "user_nodejs_active_handles_total", "legendFormat": "Users handles", "refId": "C" },
          { "expr": "listings_nodejs_active_handles_total", "legendFormat": "Listings handles", "refId": "D" },
          { "expr": "auth_nodejs_active_requests_total", "legendFormat": "Auth requests", "refId": "E" },
          { "expr": "chat_nodejs_active_requests_total", "legendFormat": "Chat requests", "refId": "F" }
