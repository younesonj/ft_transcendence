          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },
      {
        "id": 22,
        "title": "Node.js Event Loop Lag",
        "description": "Latency in the event loop — higher values indicate blocking",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
        "datasource": { "type": "prometheus", "uid": "cffduhkbhqm80f" },
        "targets": [
          { "expr": "auth_nodejs_eventloop_lag_seconds", "legendFormat": "Auth", "refId": "A" },
          { "expr": "chat_nodejs_eventloop_lag_seconds", "legendFormat": "Chat", "refId": "B" },
          { "expr": "user_nodejs_eventloop_lag_seconds", "legendFormat": "Users", "refId": "C" },
          { "expr": "listings_nodejs_eventloop_lag_seconds", "legendFormat": "Listings", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "gradientMode": "scheme", "spanNulls": true, "thresholdsStyle": { "mode": "line+area" } },
            "color": { "mode": "palette-classic" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "red", "value": 0.1 }] }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
      },
